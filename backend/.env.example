# Express Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# For production/cloud: use mongodb+srv://<username>:<password>@cluster.mongodb.net/hms
MONGODB_URI=mongodb://127.0.0.1:27017/hospital-management

# JWT Signature Secrets
JWT_ACCESS_SECRET=your_super_secret_jwt_access_token_key_12345
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_key_67890
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS Allowed Origins
CORS_ORIGIN=http://127.0.0.1:3000,http://localhost:3000

# AWS S3 Storage Secrets (Phase 4 integration)
AWS_ACCESS_KEY_ID=placeholder_aws_access_key
AWS_SECRET_ACCESS_KEY=placeholder_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=hospital-management-medical-images

# Email SMTP Settings (optional placeholders)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=placeholder_user
SMTP_PASS=placeholder_pass
SMTP_FROM=noreply@mediwellpharma.com
